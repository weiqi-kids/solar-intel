{"id": "unknown-2026-05-08-006", "date": "2026-05-08", "time_tags": {"year": 2026, "quarter": "Q2", "month": 5, "week": 19, "weekday": "Fri"}, "entities": {"companies": [], "customers": [], "suppliers": []}, "topics": ["industry_general"], "sentiment": {"label": "neutral", "score": 0.0, "keywords": []}, "importance": {"score": 0.5, "reasons": []}, "title": "New research uncovers interface-level physical mechanisms driving ultraviolet degradation in TOPCon solar cells", "content": "New research reveals that ultraviolet degradation in TOPCon solar cells is governed by interface-level physical mechanisms involving hydrogen dynamics, defect formation, and charge evolution. These processes are strongly influenced by the design of the silicon nitride/aluminum oxide passivation stack, which determines long-term device stability.", "sources": [{"name": "pv_magazine", "url": "https://www.pv-magazine.com/2026/05/08/new-research-uncovers-interface-level-physical-mechanisms-driving-ultraviolet-degradation-in-topcon-solar-cells/", "type": "rss"}]}
{"id": "unknown-2026-05-08-007", "date": "2026-05-08", "time_tags": {"year": 2026, "quarter": "Q2", "month": 5, "week": 19, "weekday": "Fri"}, "entities": {"companies": [], "customers": [], "suppliers": []}, "topics": ["industry_general"], "sentiment": {"label": "positive", "score": 0.5, "keywords": ["improve"]}, "importance": {"score": 0.5, "reasons": []}, "title": "Bandgap-engineered indoor perovskite solar cell achieves 37.44% efficiency", "content": "An international research team has improved the performance of perovskite indoor photovoltaics by tuning the absorber bandgap to better match the emission spectrum of indoor LED lighting. The approach enables improved spectral alignment under low-light conditions, with devices demonstrating efficiencies of up to 37.44% alongside long-term stability exceeding 2,000 hours.", "sources": [{"name": "pv_magazine", "url": "https://www.pv-magazine.com/2026/05/08/bandgap-engineered-indoor-perovskite-solar-cell-achieves-37-44-efficiency/", "type": "rss"}]}
